# Server-side Gemini / compatible upstream key for prompt tools.
# This is read only by the backend. Do not expose it in frontend code.
GEMINI_API_KEY=your_server_side_gemini_or_gateway_key_here
GEMINI_API_BASE_URL=https://api.bltcy.ai
PROMPT_TOOL_MODEL=gemini-3.1-pro-preview
PROMPT_OPTIMIZE_COST=0.5
REVERSE_PROMPT_COST=1

# Built-in image route keys
# Route default and line1 can be the same upstream account if you want.
IMAGE_ROUTE_DEFAULT_KEY=your_default_async_route_key_here
IMAGE_ROUTE_NANO_BANANA_PRO_LINE1_KEY=your_bltcy_line1_key_here
IMAGE_ROUTE_NANO_BANANA_PRO_LINE2_KEY=your_aittco_line2_key_here
IMAGE_ROUTE_NANO_BANANA_PRO_LINE3_KEY=your_02studio_line3_key_here

# Billing / points mode
# Set to 0 for strict recharge-only mode, or a small number if you want a tiny trial.
DEFAULT_SIGNUP_POINTS=0

# Authentication / admin
APP_NAME=Nano Banana Pro
PORT=3365
# The first registered account becomes super admin automatically.
# ADMIN_EMAILS can still be used to auto-promote specific emails to admin.
ADMIN_EMAILS=admin@example.com,ops@example.com

# MySQL storage
# Prefer MYSQL_URL in production, or use the individual MYSQL_* variables below.
# MYSQL_HOST_PORT is only used by docker-compose to bind MySQL on the host.
MYSQL_URL=
MYSQL_HOST_PORT=3310
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=nano_banana_pro
MYSQL_CONNECTION_LIMIT=10

# Email login delivery
# Production requires SMTP to send verification codes.
# Resend SMTP example:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxx
# SMTP_FROM=Nano Banana Pro <noreply@yourdomain.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM=Nano Banana Pro <noreply@example.com>

# Emergency fallback admin key for direct server-side operations only.
# Frontend no longer uses this key.
BILLING_ADMIN_API_KEY=your_emergency_admin_key_here
ANNOUNCEMENT_ADMIN_API_KEY=your_emergency_admin_key_here

# Notes:
# - Image generation now prefers the built-in route keys above.
# - The UI settings panel API Key is optional for image generation.
# - Images / points now require email login and bind to the logged-in user.
# - In non-production environments, verification codes are echoed in server logs if SMTP is not configured.
# - Port 5188: Frontend (Vite)
# - Port 3365: Backend Server (Node.js)
# - Port 3310: Host-side MySQL bind for docker-compose
